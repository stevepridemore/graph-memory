# Copy this to .env and fill in values. .env is gitignored — never commit it.

# ─── Host paths (required) ────────────────────────────────────────────────────
# GRAPH_MEMORY_HOME is the data root on the host. The MCP container mounts it
# at /root/graph-memory; Neo4j stores its data under <root>/neo4j/{data,logs,import}.
# Use absolute paths. On Windows use the C:\Users\you\graph-memory form.
GRAPH_MEMORY_HOME=/path/to/your/graph-memory

# CLAUDE_PROJECTS_DIR is the Claude Code transcripts directory (read-only mount).
# Typically ~/.claude/projects on macOS/Linux or C:\Users\you\.claude\projects on Windows.
CLAUDE_PROJECTS_DIR=/path/to/your/.claude/projects

# ─── Neo4j (local Docker by default) ──────────────────────────────────────────
# The default config in docker-compose.yml runs Neo4j Community 5.20 as a
# sibling service. The MCP container reaches it as bolt://neo4j:7687 over the
# compose internal network. Override only if you're pointing at an external
# Neo4j (e.g. Aura, a managed cluster, etc.) — must be a string ≥8 chars.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-a-strong-password
NEO4J_DATABASE=neo4j

# ─── Multi-tenant identity (always enabled, single-user by default) ───────────
# BOOTSTRAP_TENANT_ID is the admin tenant — owns the entire existing graph and
# is the only tenant allowed to call graph_cypher. For single-user setups this
# is just your email. For multi-user setups, this is the "owner" account.
BOOTSTRAP_TENANT_ID=you@example.com

# LOCAL_TENANT_ID is the tenant the stdio transport authenticates as (when you
# call MCP via docker exec). Defaults to BOOTSTRAP_TENANT_ID. Override only if
# you want stdio sessions to act as a non-admin tenant.
LOCAL_TENANT_ID=you@example.com

# TENANT_ID_SOURCE controls how HTTP requests pick a tenant.
#   static    — use LOCAL_TENANT_ID for every request (single-user, no auth)
#   cf-access — verify Cloudflare Access JWT (Cf-Access-Jwt-Assertion header)
#   header    — trust X-Graph-Memory-Tenant header (only behind a trusted proxy)
#   oauth     — verify Authorization: Bearer issued by our /oauth/token (default
#               for production deployments behind Cloudflare Tunnel)
TENANT_ID_SOURCE=static

# ─── OAuth 2.1 (only required when TENANT_ID_SOURCE=oauth) ────────────────────
# Public origin used in token iss/aud claims and OAuth metadata URLs. Should
# match the user-visible URL through your tunnel/reverse proxy.
OAUTH_ISSUER=https://localhost:3847

# ─── Cloudflare Access (only required when TENANT_ID_SOURCE=cf-access OR when
#     using OAuth mode with /oauth/authorize gated by CF Access) ──────────────
# Get these from your Cloudflare Zero Trust dashboard.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# OAUTH_ALLOWED_EMAILS — comma-separated list of allowed identities at /oauth/authorize.
# Each entry is an exact email (user@example.com) or a domain wildcard (*@example.com).
# Unset or empty → allow any identity that passes Cloudflare Access (default).
# Refresh tokens are also re-validated against this list on grant_type=refresh_token.
# OAUTH_ALLOWED_EMAILS=user@example.com
